{
  "name": "waterfall-tools",
  "version": "0.2.0",
  "description": "Tools for parsing and visualizing network waterfalls",
  "main": "dist/node/waterfall-tools.es.js",
  "module": "dist/node/waterfall-tools.es.js",
  "browser": "dist/browser/waterfall-tools/waterfall-tools.es.js",
  "exports": {
    ".": {
      "browser": "./dist/browser/waterfall-tools/waterfall-tools.es.js",
      "node": "./dist/node/waterfall-tools.es.js",
      "default": "./dist/node/waterfall-tools.es.js"
    }
  },
  "bin": {
    "waterfall-tools": "./bin/waterfall-tools.js"
  },
  "files": [
    "dist/node",
    "dist/browser/waterfall-tools",
    "dist/browser/netlog-viewer",
    "dist/browser/assets",
    "dist/browser/index.html",
    "dist/browser/index.html.br",
    "dist/browser/sw.js",
    "dist/browser/sw.js.br",
    "dist/browser/favicon.ico",
    "dist/browser/logo.jpg",
    "bin/waterfall-tools.js",
    "bin/install-viewer.js",
    "scripts/patch-devtools.js",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "build": "npm run lint && node scripts/build.js",
    "dev:demo": "vite --config vite.demo.config.js",
    "build:demo": "vite build --config vite.demo.config.js",
    "dev:viewer": "vite --config vite.dev.config.js",
    "package-release": "node scripts/package-release.js",
    "prepublishOnly": "npm run build",
    "postpublish": "npm run package-release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmeenan/waterfall-tools.git"
  },
  "keywords": [
    "waterfall",
    "har",
    "webpagetest",
    "netlog",
    "pcap",
    "tcpdump",
    "chrome-trace",
    "perfetto",
    "cdp",
    "performance"
  ],
  "author": "Patrick Meenan",
  "license": "Apache-2.0",
  "type": "module",
  "bugs": {
    "url": "https://github.com/pmeenan/waterfall-tools/issues"
  },
  "homepage": "https://github.com/pmeenan/waterfall-tools#readme",
  "devDependencies": {
    "@chrome-devtools/index": "^1.20260412.0",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "rollup": "^4.60.1",
    "sharp": "^0.34.5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@streamparser/json": "^0.0.22",
    "@streamparser/json-whatwg": "^0.0.22",
    "brotli": "^1.3.3",
    "fzstd": "^0.1.1"
  },
  "peerDependencies": {
    "@chrome-devtools/index": "^1.20260412.0"
  },
  "peerDependenciesMeta": {
    "@chrome-devtools/index": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.97"
  }
}
