  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmeenan/waterfall-tools.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/pmeenan/waterfall-tools/issues"
  },
  "homepage": "https://github.com/pmeenan/waterfall-tools#readme",
  "devDependencies": {
    "vite": "^8.0.3",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "hpack.js": "^2.1.6",
    "stream-json": "^2.0.0"
  }
